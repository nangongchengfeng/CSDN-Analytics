# Flask 配置
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=True

# 数据库配置
# SQLite (默认)
DATABASE_URL=sqlite:///csdn_analytics.db
# MySQL 配置示例
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/csdn_analytics?charset=utf8mb4

# CSDN 配置
CSDN_USER_ID=heian_99
CSDN_BLOG_URL=https://blog.csdn.net/heian_99

# 爬虫配置
SPIDER_RETRY_TIMES=3
SPIDER_RETRY_DELAY=5
SPIDER_TIMEOUT=10

# 应用配置
SECRET_KEY=your-secret-key-here
SQLALCHEMY_TRACK_MODIFICATIONS=False
SQLALCHEMY_ENGINE_OPTIONS={"connect_args": {"charset": "utf8mb4"}}
